@namespace FireCharts.Components
@typeparam TItem
@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using FireCharts.Models

<ChartSurface Title="@Title"
              Description="@Description"
              Width="@Width"
              Height="@Height"
              Responsive="@Responsive"
              HostCssClass="fire-waterfall-chart-host"
              SvgCssClass="fire-waterfall-chart">
    <ChildContent Context="surface">
        @{
            UpdateSurfaceSize(surface);
        }

        @if (Points.Count == 0)
        {
            @if (EmptyStateTemplate is not null)
            {
                @EmptyStateTemplate
            }
            else
            {
                <SvgText X="@(surface.Width / 2)"
                         Y="@(surface.Height / 2)"
                         TextAnchor="middle"
                         CssClass="empty-state"
                         Content="No data" />
            }
        }
        else
        {
            @if (ShowGridLines)
            {
                <g class="grid-lines">
                    @foreach (var tick in YAxisTicks)
                    {
                        <line x1="@Fmt(ChartAreaLeft)"
                              y1="@Fmt(tick.Position)"
                              x2="@Fmt(ChartAreaRight)"
                              y2="@Fmt(tick.Position)"
                              class="grid-line" />
                    }
                </g>
            }

            <g class="axes">
                <line x1="@Fmt(ChartAreaLeft)" y1="@Fmt(ChartAreaTop)"
                      x2="@Fmt(ChartAreaLeft)" y2="@Fmt(ChartAreaBottom)"
                      class="axis-line" />
                <line x1="@Fmt(ChartAreaLeft)" y1="@Fmt(ChartAreaBottom)"
                      x2="@Fmt(ChartAreaRight)" y2="@Fmt(ChartAreaBottom)"
                      class="axis-line" />
                @if (ZeroLineY < ChartAreaBottom - 0.5 && ZeroLineY > ChartAreaTop + 0.5)
                {
                    <line x1="@Fmt(ChartAreaLeft)"
                          y1="@Fmt(ZeroLineY)"
                          x2="@Fmt(ChartAreaRight)"
                          y2="@Fmt(ZeroLineY)"
                          class="zero-line" />
                }
            </g>

            @if (ShowAxisLabels)
            {
                <g class="value-axis-labels">
                    @foreach (var tick in YAxisTicks)
                    {
                        <SvgText X="@(ChartAreaLeft - 8)"
                                 Y="@tick.Position"
                                 CssClass="axis-label"
                                 TextAnchor="end"
                                 DominantBaseline="middle"
                                 Content="@tick.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                    }
                </g>

                <g class="category-axis-labels">
                    @foreach (var point in Points)
                    {
                        <SvgText X="@GetBarCenterX(point)"
                                 Y="@(ChartAreaBottom + 20)"
                                 CssClass="axis-label waterfall-axis-label"
                                 TextAnchor="middle"
                                 Content="@point.Label" />
                    }
                </g>
            }

            @if (ShowConnectors)
            {
                <g class="waterfall-connectors" aria-hidden="true">
                    @foreach (var connector in Connectors)
                    {
                        <line x1="@Fmt(connector.X1)"
                              y1="@Fmt(connector.Y)"
                              x2="@Fmt(connector.X2)"
                              y2="@Fmt(connector.Y)"
                              class="waterfall-connector"
                              style="@GetConnectorStyle()" />
                    }
                </g>
            }

            <g class="waterfall-series" role="list" aria-label="@Title">
                @foreach (var point in Points)
                {
                    <g @key="point.Key"
                       class="@GetPointClasses(point)"
                       role="listitem"
                       tabindex="0"
                       aria-label="@point.AccessibleLabel"
                       aria-selected="@IsSelected(point)"
                       @onmouseover="() => HandleHoverAsync(point)"
                       @onmouseout="() => HandleHoverLeaveAsync(point)"
                       @onfocus="() => HandleFocusAsync(point)"
                       @onblur="() => HandleBlurAsync(point)"
                       @onclick="() => HandleSelectAsync(point)"
                       @onkeydown="args => HandleKeyDownAsync(args, point)">
                        <rect class="waterfall-bar"
                              x="@Fmt(point.Rect.X)"
                              y="@Fmt(point.Rect.Y)"
                              width="@Fmt(point.Rect.Width)"
                              height="@Fmt(point.Rect.Height)"
                              rx="@Fmt(SafeCornerRadius)"
                              ry="@Fmt(SafeCornerRadius)"
                              style="@GetPointStyle(point)">
                            <title>@point.AccessibleLabel</title>
                        </rect>

                        @if (ShowValueLabels)
                        {
                            <SvgText X="@GetBarCenterX(point)"
                                     Y="@(point.Rect.Y - 6)"
                                     TextAnchor="middle"
                                     CssClass="waterfall-value"
                                     Content="@point.DisplayValue.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                        }
                    </g>
                }
            </g>
        }
    </ChildContent>
    <OverlayContent>
        @if (ShowTooltip && HoveredPoint is not null)
        {
            <ChartTooltip AnchorX="@GetTooltipAnchor(HoveredPoint).X"
                          AnchorY="@GetTooltipAnchor(HoveredPoint).Y"
                          ConstrainToBounds="@ConstrainTooltipToChartBounds"
                          MeasurementKey="@HoveredPoint"
                          PreferredPlacement="ChartTooltipPlacement.Above"
                          LegacyStyle="@GetTooltipStyle(HoveredPoint)"
                          Offset="10">
                @if (TooltipTemplate is not null)
                {
                    @TooltipTemplate(HoveredPoint)
                }
                else
                {
                    <div class="tooltip-series">@HoveredPoint.StepType</div>
                    <div class="tooltip-label">@HoveredPoint.Label</div>
                    <div class="tooltip-value">@HoveredPoint.DisplayValue.ToString(ValueFormat, CultureInfo.InvariantCulture)</div>
                }
            </ChartTooltip>
        }
    </OverlayContent>
</ChartSurface>
