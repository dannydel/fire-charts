@namespace FireCharts.Components
@typeparam TItem
@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using FireCharts.Models

<ChartSurface Title="@Title"
              Description="@Description"
              Width="@Width"
              Height="@Height"
              Responsive="@Responsive"
              HostCssClass="fire-bar-chart-host"
              SvgCssClass="fire-bar-chart"
              Padding="@Padding"
              OnPlotAreaChanged="OnPlotAreaChanged">
    <ChildContent>
        @if (Points.Count == 0)
        {
            @if (EmptyStateTemplate is not null)
            {
                @EmptyStateTemplate
            }
            else
            {
                <SvgText X="@(_plot.SurfaceWidth / 2)"
                         Y="@(_plot.SurfaceHeight / 2)"
                         TextAnchor="middle"
                         CssClass="empty-state"
                         Content="No data" />
            }
        }
        else
        {
            @if (ShowGridLines)
            {
                <g class="grid-lines">
                    @foreach (var tick in ValueAxisTicks)
                    {
                        if (Horizontal)
                        {
                            <line x1="@Fmt(tick.Pixel)" y1="@Fmt(_plot.Top)"
                                  x2="@Fmt(tick.Pixel)" y2="@Fmt(_plot.Bottom)"
                                  class="grid-line" />
                        }
                        else
                        {
                            <line x1="@Fmt(_plot.Left)" y1="@Fmt(tick.Pixel)"
                                  x2="@Fmt(_plot.Right)" y2="@Fmt(tick.Pixel)"
                                  class="grid-line" />
                        }
                    }
                </g>
            }

            <g class="axes">
                <line x1="@Fmt(_plot.Left)" y1="@Fmt(_plot.Top)"
                      x2="@Fmt(_plot.Left)" y2="@Fmt(_plot.Bottom)"
                      class="axis-line" />
                <line x1="@Fmt(_plot.Left)" y1="@Fmt(_plot.Bottom)"
                      x2="@Fmt(_plot.Right)" y2="@Fmt(_plot.Bottom)"
                      class="axis-line" />
            </g>

            @if (ShowAxisLabels)
            {
                <g class="value-axis-labels">
                    @foreach (var tick in ValueAxisTicks)
                    {
                        if (Horizontal)
                        {
                            <SvgText X="@tick.Pixel" Y="@(_plot.Bottom + 20)"
                                     CssClass="axis-label" TextAnchor="middle"
                                     Content="@tick.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                        }
                        else
                        {
                            <SvgText X="@(_plot.Left - 8)" Y="@tick.Pixel"
                                     CssClass="axis-label" TextAnchor="end" DominantBaseline="middle"
                                     Content="@tick.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                        }
                    }
                </g>

                <g class="category-axis-labels">
                    @foreach (var point in Points)
                    {
                        if (Horizontal)
                        {
                            <SvgText X="@(_plot.Left - 8)" Y="@(point.Rect.Y + point.Rect.Height / 2)"
                                     CssClass="axis-label" TextAnchor="end" DominantBaseline="middle"
                                     Content="@point.Label" />
                        }
                        else
                        {
                            <SvgText X="@(point.Rect.X + point.Rect.Width / 2)" Y="@(_plot.Bottom + 20)"
                                     CssClass="axis-label" TextAnchor="middle"
                                     Content="@point.Label" />
                        }
                    }
                </g>
            }

            <g class="bar-series" role="list" aria-label="@Title">
                @foreach (var point in Points)
                {
                    var fill = point.Fill;
                    var hover = point.HoverFill;
                    var pointClasses = GetPointClasses(point);
                    <g @key="point.Key"
                       class="@pointClasses"
                       role="listitem"
                       tabindex="0"
                       aria-label="@point.AccessibleLabel"
                       aria-selected="@IsSelected(point)"
                       @onmouseover="() => HandleHoverAsync(point)"
                       @onmouseout="() => HandleHoverLeaveAsync(point)"
                       @onfocus="() => HandleFocusAsync(point)"
                       @onblur="() => HandleBlurAsync(point)"
                       @onclick="() => HandleSelectAsync(point)"
                       @onkeydown="(args) => HandleKeyDownAsync(args, point)">
                        <rect class="bar-rect"
                              x="@Fmt(point.Rect.X)"
                              y="@Fmt(point.Rect.Y)"
                              width="@Fmt(point.Rect.Width)"
                              height="@Fmt(point.Rect.Height)"
                              rx="@Fmt(CornerRadius)"
                              ry="@Fmt(CornerRadius)"
                              style="--bar-color: @fill; --bar-hover-color: @hover">
                            <title>@point.AccessibleLabel</title>
                        </rect>

                        @if (ShowValueLabels)
                        {
                            @if (PointValueTemplate is not null)
                            {
                                @PointValueTemplate(point)
                            }
                            else if (Horizontal)
                            {
                                <SvgText X="@(point.Rect.X + point.Rect.Width + 6)"
                                         Y="@(point.Rect.Y + point.Rect.Height / 2)"
                                         DominantBaseline="middle"
                                         CssClass="bar-value"
                                         Content="@point.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                            }
                            else
                            {
                                <SvgText X="@(point.Rect.X + point.Rect.Width / 2)"
                                         Y="@(point.Rect.Y - 6)"
                                         TextAnchor="middle"
                                         CssClass="bar-value"
                                         Content="@point.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                            }
                        }
                    </g>
                }
            </g>
        }
    </ChildContent>
    <OverlayContent>
        @if (ShowTooltip && HoveredPoint is not null)
        {
            <ChartTooltip AnchorX="@GetTooltipAnchor(HoveredPoint).X"
                          AnchorY="@GetTooltipAnchor(HoveredPoint).Y"
                          ConstrainToBounds="@ConstrainTooltipToChartBounds"
                          MeasurementKey="@HoveredPoint"
                          PreferredPlacement="ChartTooltipPlacement.Above"
                          LegacyStyle="@GetTooltipStyle(HoveredPoint)"
                          Offset="8">
                @if (TooltipTemplate is not null)
                {
                    @TooltipTemplate(HoveredPoint)
                }
                else
                {
                    <div class="tooltip-label">@HoveredPoint.Label</div>
                    <div class="tooltip-value">@HoveredPoint.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)</div>
                }
            </ChartTooltip>
        }
    </OverlayContent>
</ChartSurface>
