@namespace FireCharts.Components
@typeparam TItem
@typeparam TSegment
@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using FireCharts.Models

<div class="@ShellCssClasses">
    @if (ShouldRenderLegendBeforeChart)
    {
        @RenderLegend()
    }

    <ChartSurface Title="@Title"
                  Description="@Description"
                  Width="@Width"
                  Height="@Height"
                  Responsive="@Responsive"
                  HostCssClass="fire-clustered-bar-chart-host"
                  SvgCssClass="fire-clustered-bar-chart"
                  Padding="@Padding"
                  OnPlotAreaChanged="OnPlotAreaChanged">
        <ChildContent>
            @if (Segments.Count == 0)
            {
                @if (EmptyStateTemplate is not null)
                {
                    @EmptyStateTemplate
                }
                else
                {
                    <SvgText X="@(_plot.SurfaceWidth / 2)"
                             Y="@(_plot.SurfaceHeight / 2)"
                             TextAnchor="middle"
                             CssClass="empty-state"
                             Content="No data" />
                }
            }
            else
            {
                @if (ShowGridLines)
                {
                    <g class="grid-lines">
                        @foreach (var tick in ValueAxisTicks)
                        {
                            if (Horizontal)
                            {
                                <line x1="@Fmt(tick.Pixel)"
                                      y1="@Fmt(_plot.Top)"
                                      x2="@Fmt(tick.Pixel)"
                                      y2="@Fmt(_plot.Bottom)"
                                      class="grid-line" />
                            }
                            else
                            {
                                <line x1="@Fmt(_plot.Left)"
                                      y1="@Fmt(tick.Pixel)"
                                      x2="@Fmt(_plot.Right)"
                                      y2="@Fmt(tick.Pixel)"
                                      class="grid-line" />
                            }
                        }
                    </g>
                }

                <g class="axes">
                    <line x1="@Fmt(_plot.Left)" y1="@Fmt(_plot.Top)"
                          x2="@Fmt(_plot.Left)" y2="@Fmt(_plot.Bottom)"
                          class="axis-line" />
                    <line x1="@Fmt(_plot.Left)" y1="@Fmt(_plot.Bottom)"
                          x2="@Fmt(_plot.Right)" y2="@Fmt(_plot.Bottom)"
                          class="axis-line" />
                </g>

                @if (ShowAxisLabels)
                {
                    <g class="value-axis-labels">
                        @foreach (var tick in ValueAxisTicks)
                        {
                            if (Horizontal)
                            {
                                <SvgText X="@tick.Pixel"
                                         Y="@(_plot.Bottom + 20)"
                                         CssClass="axis-label"
                                         TextAnchor="middle"
                                         Content="@tick.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                            }
                            else
                            {
                                <SvgText X="@(_plot.Left - 8)"
                                         Y="@tick.Pixel"
                                         CssClass="axis-label"
                                         TextAnchor="end"
                                         DominantBaseline="middle"
                                         Content="@tick.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)" />
                            }
                        }
                    </g>

                    <g class="category-axis-labels">
                        @foreach (var category in Categories)
                        {
                            if (Horizontal)
                            {
                                <SvgText X="@(_plot.Left - 8)"
                                         Y="@(category.AxisLabelPoint.Y)"
                                         CssClass="axis-label"
                                         TextAnchor="end"
                                         DominantBaseline="middle"
                                         Content="@category.Label" />
                            }
                            else
                            {
                                <SvgText X="@(category.AxisLabelPoint.X)"
                                         Y="@(_plot.Bottom + 20)"
                                         CssClass="axis-label"
                                         TextAnchor="middle"
                                         Content="@category.Label" />
                            }
                        }
                    </g>
                }

                <g class="clustered-bar-series @(HasLegendHover ? "has-legend-hover" : null)" role="list" aria-label="@Title">
                    @foreach (var category in Categories)
                    {
                        <g @key="category.Index"
                           class="clustered-category"
                           @onmouseenter="() => HandleCategoryEnterAsync(category)"
                           @onmouseleave="() => HandleCategoryLeaveAsync(category)">
                            @if (UsesSharedTooltip && category.Segments.Count > 0)
                            {
                                <rect class="clustered-bar-hover-target"
                                      x="@Fmt(category.HoverRect.X)"
                                      y="@Fmt(category.HoverRect.Y)"
                                      width="@Fmt(category.HoverRect.Width)"
                                      height="@Fmt(category.HoverRect.Height)"
                                      fill="transparent"
                                      aria-hidden="true" />
                            }

                            @foreach (var segment in category.Segments)
                            {
                                <g @key="segment.Key"
                                   class="@GetSegmentClasses(segment)"
                                   role="listitem"
                                   tabindex="0"
                                   aria-label="@segment.AccessibleLabel"
                                   aria-selected="@IsSelected(segment)"
                                   @onmouseover="() => _interaction.HoverAsync(segment)"
                                   @onmouseout="() => HandleSegmentHoverLeaveAsync(segment)"
                                   @onfocus="() => _interaction.FocusAsync(segment)"
                                   @onblur="() => _interaction.BlurAsync(segment)"
                                   @onclick="() => _interaction.ActivateAsync(segment)"
                                   @onkeydown="(args) => _interaction.KeyDownAsync(args, segment)">
                                    <rect class="clustered-segment-rect"
                                          x="@Fmt(segment.Rect.X)"
                                          y="@Fmt(segment.Rect.Y)"
                                          width="@Fmt(segment.Rect.Width)"
                                          height="@Fmt(segment.Rect.Height)"
                                          rx="@Fmt(CornerRadius)"
                                          ry="@Fmt(CornerRadius)"
                                          style="--segment-color: @segment.Fill; --segment-hover-color: @segment.HoverFill">
                                        <title>@segment.AccessibleLabel</title>
                                    </rect>
                                </g>
                            }
                        </g>
                    }
                </g>

                @if (ChartContentTemplate is not null)
                {
                    <g class="clustered-chart-content">
                        @ChartContentTemplate(ChartContext)
                    </g>
                }
            }
        </ChildContent>
        <OverlayContent>
            @if (ShowTooltip && UsesSharedTooltip && SharedTooltipContext is not null)
            {
                <ChartTooltip AnchorX="@SharedTooltipContext.Anchor.X"
                              AnchorY="@SharedTooltipContext.Anchor.Y"
                              ConstrainToBounds="@ConstrainTooltipToChartBounds"
                              MeasurementKey="@SharedTooltipContext"
                              PreferredPlacement="@(SharedTooltipContext.Horizontal ? ChartTooltipPlacement.Right : ChartTooltipPlacement.Above)"
                              LegacyStyle="@GetTooltipStyle(SharedTooltipContext)"
                              LegacyPlacementClass="@(SharedTooltipContext.Horizontal ? "chart-tooltip--side" : "chart-tooltip--top")"
                              Offset="@(SharedTooltipContext.Horizontal ? 12d : 8d)">
                    @if (SharedTooltipTemplate is not null)
                    {
                        @SharedTooltipTemplate(SharedTooltipContext)
                    }
                    else if (TooltipTemplate is not null && SharedTooltipContext.ActiveSegment is not null)
                    {
                        @TooltipTemplate(SharedTooltipContext.ActiveSegment)
                    }
                    else
                    {
                        <div class="tooltip-header">
                            <div class="tooltip-label">@SharedTooltipContext.CategoryLabel</div>
                            <div class="tooltip-total">Total @SharedTooltipContext.TotalValue.ToString(ValueFormat, CultureInfo.InvariantCulture)</div>
                        </div>
                        <div class="tooltip-list" role="list">
                            @foreach (var row in SharedTooltipContext.Rows)
                            {
                                <div class="tooltip-row @(row.IsActive ? "is-active" : null)" role="listitem">
                                    <span class="tooltip-swatch"
                                          style="@($"--tooltip-swatch-color: {row.Fill}")"
                                          aria-hidden="true"></span>
                                    <span class="tooltip-row-label">@row.SeriesLabel</span>
                                    <span class="tooltip-row-value">@row.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)</span>
                                </div>
                            }
                        </div>
                    }
                </ChartTooltip>
            }
            else if (ShowTooltip && HoveredSegment is not null)
            {
                <ChartTooltip AnchorX="@GetTooltipAnchor(HoveredSegment).X"
                              AnchorY="@GetTooltipAnchor(HoveredSegment).Y"
                              ConstrainToBounds="@ConstrainTooltipToChartBounds"
                              MeasurementKey="@HoveredSegment"
                              PreferredPlacement="@(Horizontal ? ChartTooltipPlacement.Right : ChartTooltipPlacement.Above)"
                              LegacyStyle="@GetTooltipStyle(HoveredSegment)"
                              LegacyPlacementClass="@(Horizontal ? "chart-tooltip--side" : "chart-tooltip--top")"
                              Offset="@(Horizontal ? 12d : 8d)">
                    @if (TooltipTemplate is not null)
                    {
                        @TooltipTemplate(HoveredSegment)
                    }
                    else
                    {
                        <div class="tooltip-label">@HoveredSegment.CategoryLabel</div>
                        <div class="tooltip-series">@HoveredSegment.SeriesLabel</div>
                        <div class="tooltip-value">@HoveredSegment.Value.ToString(ValueFormat, CultureInfo.InvariantCulture)</div>
                    }
                </ChartTooltip>
            }
        </OverlayContent>
    </ChartSurface>

    @if (!ShouldRenderLegendBeforeChart)
    {
        @RenderLegend()
    }
</div>

@code {
    private RenderFragment RenderLegend() => @<text>
        @if (ShowLegend && LegendItems.Count > 0)
        {
            <div class="clustered-bar-legend" role="list" aria-label="@($"{Title} legend")">
                @foreach (var legendItem in LegendItems)
                {
                    <button type="button"
                            class="@GetLegendItemClasses(legendItem)"
                            role="listitem"
                            @onmouseover="() => HandleLegendEnter(legendItem.Label)"
                            @onmouseout="HandleLegendLeave"
                            @onfocus="() => HandleLegendEnter(legendItem.Label)"
                            @onblur="HandleLegendLeave">
                        <span class="clustered-bar-legend__swatch"
                              style="@($"--legend-color: {legendItem.Fill}")"
                              aria-hidden="true"></span>
                        <span class="clustered-bar-legend__label">@legendItem.Label</span>
                    </button>
                }
            </div>
        }
    </text>;
}
