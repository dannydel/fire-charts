    private string HomeUsageExample => """
@using FireCharts.Components
@using FireCharts.Models

<FireLineChart TItem="WeeklyPoint"
               Title="Inspections completed"
               Description="Weekly completions across districts"
               Responsive="true"
               Items="@Points"
               XValueSelector="point => LineChartXValue.FromDateTime(point.Date)"
               YValueSelector="point => point.Completed"
               LabelSelector="point => point.Label"
               HighlightSelector="point => point.IsMilestone">
    <TooltipTemplate Context="point">
        <div>@point.Label</div>
        <div>@point.Y completed</div>
    </TooltipTemplate>
</FireLineChart>
""";

    private sealed record HeroTrendPoint(DateTime Date, double Value, string Label, bool Highlight);
    private sealed record MiniTrendPoint(DateTime Date, double Value, string Label, bool Highlight);
    private sealed record MiniBarPoint(string Label, double Value, string Color, string HoverColor);
    private sealed record MiniSlice(string Label, double Value, string Color);
    private sealed record MiniScatterPoint(string Label, double Volume, double ResponseMinutes, string Color, string HoverColor);
    private sealed record MiniHeatmapPoint(string DayKey, string DayLabel, int DayOrder, string ShiftKey, string ShiftLabel, int ShiftOrder, double Value);
    private sealed record MiniWaterfallPoint(string Label, double Value, WaterfallStepType StepType);
}
