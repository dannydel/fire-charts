    private const int MaxPlaygroundSeries = 10;
    private int PlaygroundSeriesCount { get; set; } = 2;

    private LineChartVariant PlaygroundVariant { get; set; } = LineChartVariant.Line;
    private LineInterpolationMode PlaygroundInterpolation { get; set; } = LineInterpolationMode.Smooth;
    private LinePointDisplayMode PlaygroundPointDisplayMode { get; set; } = LinePointDisplayMode.HighlightedOnly;
    private bool PlaygroundShowGridLines { get; set; } = true;
    private bool PlaygroundShowAxisLabels { get; set; } = true;
    private bool PlaygroundShowLegend { get; set; } = true;
    private bool PlaygroundShowTooltip { get; set; } = true;
    private double PlaygroundCurveTension { get; set; } = 0.85;
    private double PlaygroundAreaOpacity { get; set; } = 0.18;
    private int PlaygroundXAxisTickCount { get; set; } = 5;
    private int PlaygroundYAxisTickCount { get; set; } = 5;

    private IReadOnlyList<LineChartSeries<TrendPoint>> PlaygroundSeries =>
        AllPlaygroundSeries.Take(PlaygroundSeriesCount).ToList();

    private IReadOnlyList<LineChartSeries<TrendPoint>> AllPlaygroundSeries =>
    [
        new("Permits", PermitComparisonTrend, "#d94f3d", FillColor: "#d94f3b"),
        new("Inspections", InspectionComparisonTrend, "#198f8c", FillColor: "#198f8c"),
        new("Service requests", ServiceRequestsTrend, "#8a7cf6", FillColor: "#8a7cf6"),
        new("Portal adoption", PortalAdoptionTrend, "#e79b21", FillColor: "#e79b21"),
        new("Plan reviews", PlanReviewsTrend, "#4d89ff", FillColor: "#4d89ff"),
        new("Field calls", FieldCallsTrend, "#d86ca6", FillColor: "#d86ca6"),
        new("Compliance", ComplianceTrend, "#3f7d44", FillColor: "#3f7d44"),
        new("Staffing", StaffingTrend, "#7d5a50", FillColor: "#7d5a50"),
        new("Renewals", RenewalsTrend, "#5c6bc0", FillColor: "#5c6bc0"),
        new("Resubmittals", ResubmittalsTrend, "#c97a1f", FillColor: "#c97a1f")
    ];

    private bool CanAddPlaygroundSeries => PlaygroundSeriesCount < MaxPlaygroundSeries;
    private bool CanRemovePlaygroundSeries => PlaygroundSeriesCount > 1;

    private void ResetLinePlayground()
    {
        PlaygroundSeriesCount = 2;
        PlaygroundVariant = LineChartVariant.Line;
        PlaygroundInterpolation = LineInterpolationMode.Smooth;
        PlaygroundPointDisplayMode = LinePointDisplayMode.HighlightedOnly;
        PlaygroundShowGridLines = true;
        PlaygroundShowAxisLabels = true;
        PlaygroundShowLegend = true;
        PlaygroundShowTooltip = true;
        PlaygroundCurveTension = 0.85;
        PlaygroundAreaOpacity = 0.18;
        PlaygroundXAxisTickCount = 5;
        PlaygroundYAxisTickCount = 5;
    }

    private void AddPlaygroundSeries()
    {
        if (!CanAddPlaygroundSeries)
        {
            return;
        }

        PlaygroundSeriesCount++;
    }

    private void RemovePlaygroundSeries()
    {
        if (!CanRemovePlaygroundSeries)
        {
            return;
        }

        PlaygroundSeriesCount--;
    }

    private static string GetTrendLabel(TrendPoint point) =>
        point.Highlight && !string.IsNullOrWhiteSpace(point.Annotation)
            ? point.Annotation
            : point.Date.ToString("MMM d", CultureInfo.InvariantCulture);

    private static string GetStepLabel(TrendPoint point) => point.Annotation;

    private static string GetResponseState(double value) =>
        value switch
        {
            >= 3 => "Peak staffing response",
            >= 2 => "Elevated staffing response",
            >= 1 => "Normal staffing response",
            _ => "Quiet coverage period"
        };

    private string LineChartUsageExample => """
@using FireCharts.Components
@using FireCharts.Models

@code {
    private IReadOnlyList<ServiceTrend> trend =
    [
        new(new DateTime(2025, 1, 6), 118, false, null),
        new(new DateTime(2025, 1, 13), 126, false, null),
        new(new DateTime(2025, 1, 20), 131, true, "Review queue spike"),
        new(new DateTime(2025, 1, 27), 129, false, null)
    ];

    private sealed record ServiceTrend(DateTime Date, double Value, bool Highlight, string? Note);
}

<FireLineChart TItem="ServiceTrend"
               Title="Permit application volume"
               Description="Weekly permit submissions"
               Items="@trend"
               XValueSelector="item => LineChartXValue.FromDateTime(item.Date)"
               YValueSelector="item => item.Value"
               LabelSelector="item => item.Date.ToString(""MMM d"")"
               HighlightSelector="item => item.Highlight"
               Responsive="true"
               Interpolation="LineInterpolationMode.Smooth">
    <TooltipTemplate Context="point">
        <div>@point.X.ToDateTime().ToString("MMM d")</div>
        <div>@point.Y.ToString("F0") submissions</div>
        @if (!string.IsNullOrWhiteSpace(point.Item.Note))
        {
            <div>@point.Item.Note</div>
        }
    </TooltipTemplate>
</FireLineChart>
""";

    private IReadOnlyList<ExampleApiItem> LineChartApiItems { get; } =
    [
        new("Items or Series", "Pass one list for a simple line, or a list of LineChartSeries<TItem> when you want multiple comparison lines in the same chart."),
        new("XValueSelector and YValueSelector", "Map each item to its X and Y coordinates. Use LineChartXValue.FromDateTime(...) for time-based axes."),
        new("Interpolation and CurveTension", "Switch between smooth, linear, and step lines. CurveTension only affects the smooth interpolation mode."),
        new("PointDisplayMode and HighlightSelector", "Keep the chart visually calm by surfacing only highlighted milestones, or turn on markers for every point."),
        new("Variant", "Choose between a standard line and an area chart without changing the underlying data shape."),
        new("ShowLegend, ShowTooltip, XAxisTickCount, and YAxisTickCount", "Tune dashboard density and supporting affordances to match the surrounding layout."),
        new("@bind-SelectedPoint and TooltipTemplate", "Coordinate chart selection with the rest of your UI and fully customize the hover content when the defaults are not enough.")
    ];

    private sealed record TrendPoint(DateTime Date, double Value, string Annotation = "", bool Highlight = false, string? Note = null);
}
