@inherits LayoutComponentBase

<a class="skip-link" href="#main-content">Skip to content</a>

<div class="app-shell">
    <aside class="sidebar @(isNavCompact ? "sidebar--compact" : null)">
        <NavMenu OnCompactChanged="HandleNavCompactChanged" />
    </aside>

    <div class="app-frame">
        <header class="top-row">
            <div class="top-row__content">
                <p class="top-row__eyebrow">FireCharts Example Site</p>
                <p class="top-row__title">Typed Blazor charts for dashboards, reporting, and operational analysis.</p>
                <p class="top-row__summary">
                    Explore the library by chart family, interaction pattern, and production-ready example rather than
                    generic sample-app pages.
                </p>
            </div>

            <div class="top-row__actions">
                <a class="top-row__action top-row__action--primary" href="">Overview</a>
                <a class="top-row__action" href="linechart">Trend demos</a>
                <a class="top-row__action" href="heatmapchart">Operational views</a>
            </div>
        </header>

        <main id="main-content" tabindex="-1">
            <article class="content-shell">
                @Body
            </article>
        </main>
    </div>
</div>

@code {
    private bool isNavCompact = true;

    private Task HandleNavCompactChanged(bool compact)
    {
        isNavCompact = compact;
        return Task.CompletedTask;
    }
}
